<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_risolvo_assistance_ticket_tree" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.tree</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <tree decoration-danger="is_sla_late" decoration-muted="state in ('closed', 'cancelled')">
                <field name="name"/>
                <field name="title"/>
                <field name="site_id"/>
                <field name="asset_id"/>
                <field name="category"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="assigned_user_id"/>
                <field name="sla_deadline"/>
                <field name="is_sla_late"/>
            </tree>
        </field>
    </record>

    <record id="view_risolvo_assistance_ticket_kanban" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.kanban</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="title"/>
                <field name="priority"/>
                <field name="site_id"/>
                <field name="asset_id"/>
                <field name="assigned_user_id"/>
                <field name="is_sla_late"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click #{record.is_sla_late.raw_value ? 'oe_kanban_color_1' : ''}">
                            <strong><field name="title"/></strong>
                            <div><field name="name"/></div>
                            <div><field name="site_id"/></div>
                            <div><field name="asset_id"/></div>
                            <div class="mt8">
                                <field name="priority" widget="priority"/>
                                <field name="assigned_user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_risolvo_assistance_ticket_search" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.search</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="site_id"/>
                <field name="asset_id"/>
                <field name="assigned_user_id"/>
                <filter name="open" string="Aperti" domain="[('state', 'not in', ('resolved', 'closed', 'cancelled'))]"/>
                <filter name="mine" string="Miei ticket" domain="[('assigned_user_id', '=', uid)]"/>
                <filter name="to_plan" string="Da pianificare" domain="[('state', 'in', ('new', 'qualified', 'waiting_customer'))]"/>
                <filter name="late" string="SLA scaduto" domain="[('is_sla_late', '=', True)]"/>
                <filter name="urgent" string="Urgenti" domain="[('priority', '=', '3')]"/>
                <filter name="planned_today" string="Pianificati oggi" domain="[('planned_datetime', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('planned_datetime', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_state" string="Stato" context="{'group_by': 'state'}"/>
                    <filter name="group_site" string="Sede/Reparto" context="{'group_by': 'site_id'}"/>
                    <filter name="group_asset" string="Asset" context="{'group_by': 'asset_id'}"/>
                    <filter name="group_user" string="Responsabile" context="{'group_by': 'assigned_user_id'}"/>
                    <filter name="group_category" string="Categoria" context="{'group_by': 'category'}"/>
                    <filter name="group_priority" string="Priorita" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_risolvo_assistance_ticket_graph" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.graph</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <graph string="Ticket per stato" type="bar">
                <field name="state"/>
                <field name="priority"/>
            </graph>
        </field>
    </record>

    <record id="view_risolvo_assistance_ticket_pivot" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.pivot</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Analisi ticket">
                <field name="state" type="row"/>
                <field name="priority" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_risolvo_assistance_ticket_calendar" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.calendar</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <calendar string="Pianificazione ticket" date_start="planned_datetime" color="assigned_user_id">
                <field name="name"/>
                <field name="title"/>
                <field name="site_id"/>
                <field name="assigned_user_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_risolvo_assistance_ticket_form" model="ir.ui.view">
        <field name="name">risolvo.assistance.ticket.form</field>
        <field name="model">risolvo.assistance.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_qualify" string="Qualifica" type="object" class="btn-primary" invisible="state != 'new'"/>
                    <button name="action_plan" string="Pianifica" type="object" class="btn-primary" invisible="state not in ('qualified', 'waiting_customer')"/>
                    <button name="action_start" string="Avvia lavorazione" type="object" class="btn-primary" invisible="state not in ('new', 'qualified', 'planned')"/>
                    <button name="action_wait_customer" string="Attesa cliente" type="object" invisible="state not in ('in_progress', 'planned')"/>
                    <button name="action_resolve" string="Risolvi" type="object" class="btn-primary" invisible="state not in ('in_progress', 'waiting_customer', 'planned')"/>
                    <button name="action_close" string="Chiudi" type="object" invisible="state != 'resolved'"/>
                    <button name="action_cancel" string="Annulla" type="object" invisible="state in ('closed', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,qualified,planned,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_interventions" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="intervention_count" widget="statinfo" string="Interventi"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="SLA scaduto" bg_color="text-bg-danger" invisible="not is_sla_late"/>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="Sintesi richiesta"/></h1>
                        <h3><field name="name"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="requester_id"/>
                            <field name="site_id"/>
                            <field name="asset_id"/>
                            <field name="channel"/>
                        </group>
                        <group>
                            <field name="assigned_user_id"/>
                            <field name="category"/>
                            <field name="priority" widget="priority"/>
                            <field name="sla_id"/>
                            <field name="sla_deadline"/>
                            <field name="planned_datetime"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Richiesta">
                            <field name="description"/>
                            <field name="impact"/>
                            <field name="workaround"/>
                        </page>
                        <page string="Interventi">
                            <field name="intervention_ids" context="{'default_ticket_id': id}">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="technician_id"/>
                                    <field name="intervention_type"/>
                                    <field name="state"/>
                                    <field name="start_datetime"/>
                                    <field name="end_datetime"/>
                                    <field name="duration_hours"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Risoluzione">
                            <field name="root_cause"/>
                            <field name="resolution"/>
                        </page>
                        <page string="Date">
                            <group>
                                <field name="first_response_datetime"/>
                                <field name="resolved_datetime"/>
                                <field name="closed_datetime"/>
                                <field name="is_sla_late"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_risolvo_assistance_ticket" model="ir.actions.act_window">
        <field name="name">Ticket assistenza</field>
        <field name="res_model">risolvo.assistance.ticket</field>
        <field name="view_mode">kanban,tree,form,calendar,graph,pivot</field>
        <field name="search_view_id" ref="view_risolvo_assistance_ticket_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>

    <record id="action_risolvo_assistance_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard assistenza</field>
        <field name="res_model">risolvo.assistance.ticket</field>
        <field name="view_mode">kanban,graph,pivot,tree,form</field>
        <field name="search_view_id" ref="view_risolvo_assistance_ticket_search"/>
        <field name="context">{'search_default_open': 1, 'search_default_group_state': 1}</field>
    </record>

    <record id="action_risolvo_assistance_my_ticket" model="ir.actions.act_window">
        <field name="name">Miei ticket</field>
        <field name="res_model">risolvo.assistance.ticket</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="search_view_id" ref="view_risolvo_assistance_ticket_search"/>
        <field name="context">{'search_default_open': 1, 'search_default_mine': 1}</field>
    </record>

    <record id="action_risolvo_assistance_ticket_to_plan" model="ir.actions.act_window">
        <field name="name">Da pianificare</field>
        <field name="res_model">risolvo.assistance.ticket</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="search_view_id" ref="view_risolvo_assistance_ticket_search"/>
        <field name="context">{'search_default_to_plan': 1}</field>
    </record>

    <record id="action_risolvo_assistance_ticket_late" model="ir.actions.act_window">
        <field name="name">SLA scaduti</field>
        <field name="res_model">risolvo.assistance.ticket</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_risolvo_assistance_ticket_search"/>
        <field name="context">{'search_default_late': 1}</field>
    </record>
</odoo>
