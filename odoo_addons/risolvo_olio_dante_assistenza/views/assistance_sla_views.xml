<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_risolvo_assistance_sla_tree" model="ir.ui.view">
        <field name="name">risolvo.assistance.sla.tree</field>
        <field name="model">risolvo.assistance.sla</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="category"/>
                <field name="priority"/>
                <field name="response_hours"/>
                <field name="resolution_hours"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_risolvo_assistance_sla_form" model="ir.ui.view">
        <field name="name">risolvo.assistance.sla.form</field>
        <field name="model">risolvo.assistance.sla</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="priority"/>
                        <field name="response_hours"/>
                        <field name="resolution_hours"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_risolvo_assistance_sla" model="ir.actions.act_window">
        <field name="name">SLA</field>
        <field name="res_model">risolvo.assistance.sla</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
