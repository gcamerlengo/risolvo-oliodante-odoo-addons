<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_risolvo_assistance_asset_tree" model="ir.ui.view">
        <field name="name">risolvo.assistance.asset.tree</field>
        <field name="model">risolvo.assistance.asset</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="site_id"/>
                <field name="asset_type"/>
                <field name="criticality"/>
                <field name="vendor"/>
            </tree>
        </field>
    </record>

    <record id="view_risolvo_assistance_asset_form" model="ir.ui.view">
        <field name="name">risolvo.assistance.asset.form</field>
        <field name="model">risolvo.assistance.asset</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="site_id"/>
                            <field name="partner_id"/>
                            <field name="asset_type"/>
                            <field name="criticality"/>
                        </group>
                        <group>
                            <field name="vendor"/>
                            <field name="model"/>
                            <field name="installation_date"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ticket">
                            <field name="ticket_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="priority"/>
                                    <field name="state"/>
                                    <field name="assigned_user_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Note">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_risolvo_assistance_asset" model="ir.actions.act_window">
        <field name="name">Asset</field>
        <field name="res_model">risolvo.assistance.asset</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
